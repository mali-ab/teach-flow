# Go backend configuration for TeachFlow

# Backend listen port
BACKEND_PORT=8080

# Salt used to hash passwords in memory. Change for your own deployment.
PASSWORD_SALT=teachflow-salt

# Your Jitsi deployment base URL.
# Example for local Jitsi docker: http://localhost:8000
JITSI_BASE_URL=http://localhost:8000

# Optional JWT settings for secure Jitsi deployments.
# If you run Jitsi with JWT auth enabled, set these values.
JITSI_APP_ID=
JITSI_APP_SECRET=
